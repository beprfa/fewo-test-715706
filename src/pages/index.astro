---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import AvailabilityCalendar from '~/components/AvailabilityCalendar.astro';

import ImageCarousel from '~/components/ImageCarousel.astro';

// %%%APARTMENT_IMPORTS_START%%%
import ap1 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-1.jpg';
import ap2 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-2.jpg';
import ap3 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-3.jpg';
import ap4 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-4.jpg';
import ap5 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-5.jpg';
import ap6 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-6.jpg';
import ap7 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-7.jpg';
import ap8 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-8.jpg';

import lh1 from '~/assets/images/landhaus/bauernhof-01.jpg';
import lh2 from '~/assets/images/landhaus/bauernhof-02.jpg';
import lh3 from '~/assets/images/landhaus/bauernhof-03.jpg';
import lh4 from '~/assets/images/landhaus/bauernhof-04.jpg';
import lh5 from '~/assets/images/landhaus/bauernhof-05.jpg';
import lh6 from '~/assets/images/landhaus/bauernhof-06.jpg';

import bw1 from '~/assets/images/apartments/bergwiese/bergwiese-1.jpg';
import bw2 from '~/assets/images/apartments/bergwiese/bergwiese-2.jpg';
import bw3 from '~/assets/images/apartments/bergwiese/bergwiese-3.jpg';
import bw4 from '~/assets/images/apartments/bergwiese/bergwiese-4.jpg';
import bw5 from '~/assets/images/apartments/bergwiese/bergwiese-5.jpg';
import bw6 from '~/assets/images/apartments/bergwiese/bergwiese-6.jpg';
// %%%APARTMENT_IMPORTS_END%%%

// %%%APARTMENT_IMAGE_ARRAYS_START%%%
const alpenpanoramaImages = [
  { src: ap1, alt: 'Alpenpanorama 1' },
  { src: ap2, alt: 'Alpenpanorama 2' },
  { src: ap3, alt: 'Alpenpanorama 3' },
  { src: ap4, alt: 'Alpenpanorama 4' },
  { src: ap5, alt: 'Alpenpanorama 5' },
  { src: ap6, alt: 'Alpenpanorama 6' },
  { src: ap7, alt: 'Alpenpanorama 7' },
  { src: ap8, alt: 'Alpenpanorama 8' },
];

const landhausImages = [
  { src: lh1, alt: 'Sonnenhof Alpenblick Landhaus' },
  { src: lh2, alt: 'Sonnenhof Alpenblick Garten' },
  { src: lh3, alt: 'Sonnenhof Alpenblick Terrasse' },
  { src: lh4, alt: 'Sonnenhof Alpenblick Umgebung' },
  { src: lh5, alt: 'Sonnenhof Alpenblick Aussicht' },
  { src: lh6, alt: 'Sonnenhof Alpenblick Eingang' },
];

const bergwieseImages = [
  { src: bw1, alt: 'Bergwiese 1' },
  { src: bw2, alt: 'Bergwiese 2' },
  { src: bw3, alt: 'Bergwiese 3' },
  { src: bw4, alt: 'Bergwiese 4' },
  { src: bw5, alt: 'Bergwiese 5' },
  { src: bw6, alt: 'Bergwiese 6' },
];
// %%%APARTMENT_IMAGE_ARRAYS_END%%%

const metadata = {
  title: 'Musterhaus Sonnenschein – Ferienwohnungen in Prien am Chiemsee',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'secondary',
        text: 'Buchungsanfrage',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { variant: 'primary', text: 'Wohnungen ansehen', href: '#ferienwohnungen' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Musterhaus Sonnenschein – Ferienwohnungen in Prien am Chiemsee' }}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-white">Willkommen in unserer Ferienwohnung</span>
    </Fragment>

    <Fragment slot="subtitle">
      Erholung pur am Chiemsee
    </Fragment>
  </Hero>

  <!-- Ferienwohnungen Section *************** -->

  <section id="ferienwohnungen" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Ferienwohnungen</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">Ihre Ferienwohnungen in Prien am Chiemsee</h2>
        <p class="text-lg text-muted dark:text-slate-400">
          Nichtraucher-Haus. Haustiere auf Anfrage. Parkplatz vorhanden.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-lg text-default dark:text-slate-300 mb-8">
        <!-- %%%BUILDING_AMENITIES_DE_START%%% -->
        <span class="flex items-center gap-1.5"><Icon name="tabler:trees" class="w-5 h-5" /> Garten</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sun" class="w-5 h-5" /> Terrasse</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:flame" class="w-5 h-5" /> Grillplatz</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:wifi" class="w-5 h-5" /> WLAN</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:car" class="w-5 h-5" /> Parkplätze</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:mood-kid" class="w-5 h-5" /> Kinder willkommen</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:paw" class="w-5 h-5" /> Haustiere erlaubt</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sparkles" class="w-5 h-5" /> 2025 renoviert</span>
        <!-- %%%BUILDING_AMENITIES_DE_END%%% -->
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <!-- %%%APARTMENT_CARDS_DE_START%%% -->
        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={alpenpanoramaImages} id="alpenpanorama" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Alpenpanorama</h3>
            <p class="text-lg text-muted dark:text-slate-400 mb-3">Unsere größte Wohnung im Erdgeschoss mit schönem Blick auf die Alpen. Ideal für Familien.</p>
            <p class="text-lg font-semibold text-primary mb-3">Ab 60 € / Nacht (1 Pers.) · 75 € / Nacht (2 Pers.)</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-lg text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-5 h-5" /> 110 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-5 h-5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-5 h-5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-5 h-5" /> Einzelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-5 h-5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-5 h-5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-5 h-5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-5 h-5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-5 h-5" /> Wohnzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-5 h-5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-5 h-5" /> WLAN</span>
            </div>
            <AvailabilityCalendar apartment="alpenpanorama" id="alpenpanorama" />
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={bergwieseImages} id="bergwiese" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Bergwiese</h3>
            <p class="text-lg text-muted dark:text-slate-400 mb-3">Gemütliche Wohnung im Erdgeschoss mit Blick auf den Garten. Ideal für eine Auszeit zu zweit.</p>
            <p class="text-lg font-semibold text-primary mb-3">Ab 45 € / Nacht (1 Pers.) · 60 € / Nacht (2 Pers.)</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-lg text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-5 h-5" /> 20 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-5 h-5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-5 h-5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-5 h-5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-5 h-5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-5 h-5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-5 h-5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-5 h-5" /> Wohnzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-5 h-5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-5 h-5" /> WLAN</span>
              <span class="flex items-center gap-1"><Icon name="tabler:trees" class="w-5 h-5" /> Gartenzugang</span>
            </div>
            <AvailabilityCalendar apartment="bergwiese" id="bergwiese" />
          </div>
        </div>
        <!-- %%%APARTMENT_CARDS_DE_END%%% -->

      </div>

      <div class="text-center mt-8">
        <a href="/contact" class="btn btn-secondary font-semibold bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-6 py-3 rounded-full inline-block">Buchungsanfrage</a>
      </div>
    </div>
  </section>

  <!-- Willkommen Section **************** -->

  <section id="landhaus" class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-8 md:mb-12">
        <p class="text-base text-primary dark:text-blue-200 font-bold tracking-wide uppercase mb-2">Willkommen im Musterhaus Sonnenschein</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tighter font-heading dark:text-gray-200">Ihr Zuhause in Prien am Chiemsee</h2>
      </div>
      <div class="md:flex md:flex-row-reverse md:gap-16">
        <div class="md:basis-1/2 self-center mb-8 md:mb-0">
          <p class="text-lg dark:text-slate-400">
            Direkt am See gelegen mit Blick auf die Alpen. Wanderwege, Radwege und Schifffahrt in unmittelbarer Nähe.
          </p>
        </div>
        <div class="md:basis-1/2">
          <div class="rounded-lg overflow-hidden shadow-lg">
            <ImageCarousel images={landhausImages} id="landhaus" imageClass="w-full aspect-[3/2] object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- Anreise Section *************** -->

  <section id="anreise" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Anreise</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">So kommen Sie zu uns</h2>
      </div>

      <!-- %%%ANREISE_MAP_START%%% -->
      <div class="text-center mb-6">
        <p class="text-lg text-default dark:text-slate-300">Bergstraße 7, 83229 Aschau im Chiemgau</p>
      </div>

      <div class="rounded-lg overflow-hidden mx-auto mb-6" style="aspect-ratio: 16/9; max-width: 900px;">
        <iframe
          title="Standort des Sonnenhof Alpenblick"
          width="100%"
          height="100%"
          style="border: 0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.openstreetmap.org/export/embed.html?bbox=12.3050%2C47.7650%2C12.3400%2C47.7850&layer=mapnik&marker=47.7750%2C12.3230"
        ></iframe>
      </div>

      <div class="text-center">
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=Bergstra%C3%9Fe+7,+83229+Aschau+im+Chiemgau"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary font-semibold bg-primary text-white border-primary hover:bg-secondary hover:border-secondary px-6 py-3 rounded-full inline-block"
        >
          Route planen
        </a>
      </div>
      <!-- %%%ANREISE_MAP_END%%% -->
    </div>
  </section>

  <!-- FAQs Widget ******************* -->

  {/* %%%FAQ_ITEMS_DE_START%%% */}
  <FAQs
    title="Häufig gestellte Fragen"
    subtitle="Hier finden Sie Antworten auf die wichtigsten Fragen rund um Ihren Aufenthalt im Musterhaus Sonnenschein."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Wann ist Check-in und Check-out?',
        description:
          'Der Check-in ist ab 15:00 Uhr möglich, der Check-out bis 10:00 Uhr. Nach Absprache sind auch andere Zeiten möglich.',
      },
      {
        title: 'Gibt es Parkmöglichkeiten?',
        description:
          'Ja, kostenlose Parkplätze stehen direkt am Haus zur Verfügung.',
      },
      {
        title: 'Sind Haustiere erlaubt?',
        description:
          'Bitte kontaktieren Sie uns vorab, wenn Sie ein Haustier mitbringen möchten. Wir finden sicher eine Lösung.',
      },
      {
        title: 'Wie weit ist es zum Chiemsee?',
        description:
          'Der Chiemsee ist ca. 15 Autominuten entfernt. Auch die Kampenwand-Seilbahn und das Zentrum von Aschau sind schnell erreichbar.',
      },
      {
        title: 'Sind Kinder willkommen?',
        description:
          'Selbstverständlich! Ein Babybett und ein Zustellbett sind auf Anfrage verfügbar. Bitte teilen Sie uns bei der Buchung mit, ob Sie eines benötigen.',
      },
      {
        title: 'Wie kann ich buchen?',
        description:
          'Senden Sie uns einfach eine Anfrage über unser Kontaktformular oder per E-Mail an info@sonnenhof-alpenblick.de. Wir melden uns schnellstmöglich bei Ihnen.',
      },
    ]}
  />
  {/* %%%FAQ_ITEMS_DE_END%%% */}

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'secondary',
        text: 'Buchungsanfrage',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Ihr Urlaub im&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Prien am Chiemsee wartet</span>
    </Fragment>

    <Fragment slot="subtitle">
      Sichern Sie sich Ihren Wunschtermin im Musterhaus Sonnenschein. <br class="hidden md:inline" />
      Wir freuen uns auf Ihre Anfrage!
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-100 dark:bg-slate-800"></div>
    </Fragment>
  </CallToAction>
</Layout>
